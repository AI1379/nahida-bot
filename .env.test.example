# Copy this file to .env.test (or .env) and fill real values.
# tests/conftest.py loads .env then .env.test automatically.

# OpenAI-compatible endpoint base URL, for example:
# https://api.openai.com/v1
NAHIDA_LIVE_OPENAI_BASE_URL=

# API key for the configured backend.
# You can alternatively set OPENAI_API_KEY.
NAHIDA_LIVE_OPENAI_API_KEY=

# Model name for live test.
NAHIDA_LIVE_OPENAI_MODEL=

# Optional fallback key name supported by fixture:
# OPENAI_API_KEY=
