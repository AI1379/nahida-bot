# =============================================================================
# Nahida Bot — Integration Test Environment Variables
# =============================================================================
#
# Copy this file to .env.test and fill in your API keys.
# .env.test is gitignored — your secrets stay local.
#
# The test suite loads .env.test automatically via conftest.py.
# Tests that require these keys are marked with @pytest.mark.live
# and will be skipped when the corresponding keys are missing.
#
# Usage:
#   cp .env.test.example .env.test
#   # Edit .env.test with your keys
#   uv run pytest tests/integration/ -m live
#

# ── OpenAI Compatible ──
# Any OpenAI-compatible endpoint (OpenAI, Azure, local LLM, etc.)
NAHIDA_LIVE_OPENAI_BASE_URL=
NAHIDA_LIVE_OPENAI_API_KEY=
NAHIDA_LIVE_OPENAI_MODEL=

# Optional fallback key name:
# OPENAI_API_KEY=

# ── DeepSeek ──
# DeepSeek API (deepseek-chat supports both reasoning and tool calling)
# Base URL defaults to https://api.deepseek.com if not set
NAHIDA_LIVE_DEEPSEEK_API_KEY=
# NAHIDA_LIVE_DEEPSEEK_BASE_URL=https://api.deepseek.com
# NAHIDA_LIVE_DEEPSEEK_MODEL=deepseek-chat

# ── Anthropic / Claude ──
# Anthropic Messages API
# Base URL defaults to https://api.anthropic.com if not set
NAHIDA_LIVE_ANTHROPIC_API_KEY=
# NAHIDA_LIVE_ANTHROPIC_BASE_URL=https://api.anthropic.com
# NAHIDA_LIVE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional fallback key name:
# ANTHROPIC_API_KEY=
